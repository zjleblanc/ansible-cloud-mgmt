---
# https://ansible.readthedocs.io/projects/lint/configuring/
profile: production

exclude_paths:
  - .cache/
  - .venv/
  - vaulted/
  - archive/
  # Vault ciphertext — not lintable Ansible source
  - demos/vars/secrets.yml

# First match wins — classify task/vars files before playbook heuristics
# kick in for paths under playbooks/ or demos/.
kinds:
  - tasks: "**/tasks/*.{yml,yaml}"
  - vars: "**/vars/*.{yml,yaml}"
  - handlers: "**/handlers/*.{yml,yaml}"
  - meta: "**/meta/main.{yml,yaml}"
  - inventory: "inventories/**/*.{yml,yaml}"
  - requirements: "{collections,tests}/requirements.{yml,yaml}"
  - yaml: "**/ansible-navigator.{yml,yaml}"

# Satisfy syntax-check for playbooks that expect AAP/extra vars at runtime.
# These do not change playbook runtime behavior.
extra_vars:
  _host: localhost
  _hosts: localhost

offline: false
use_default_rules: true
